<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/journalBackground"
    android:orientation="vertical"
    tools:context=".activities.SettingsActivity">

    <include layout="@layout/toolbar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Card: Avatar e e-mail do perfil -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_auth_gradient"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="28dp"
                android:paddingEnd="24dp"
                android:paddingBottom="28dp">

                <!-- Avatar clicável -->
                <FrameLayout
                    android:id="@+id/frameAvatar"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:clickable="true"
                    android:focusable="true">

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/imageAvatar"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:src="@drawable/ic_person_24"
                        app:civ_border_width="2dp"
                        app:civ_border_color="@color/journalHighlight" />

                    <!-- Badge de câmera -->
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="bottom|end"
                        android:background="@drawable/bg_icon_circle"
                        android:padding="4dp"
                        android:src="@drawable/ic_camera_24"
                        android:contentDescription="@string/settings_change_photo" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/settings_change_photo"
                    android:textColor="@color/journalHighlight"
                    android:textSize="12sp" />

                <!-- E-mail (somente leitura) -->
                <TextView
                    android:id="@+id/textProfileEmailValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    tools:text="usuario@email.com" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/profile_editor_subtitle"
                    android:textColor="@color/journalHighlight"
                    android:textSize="12sp"
                    android:textAlignment="center" />
            </LinearLayout>

            <!-- Card: Campos editáveis -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_surface_card"
                android:elevation="4dp"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Rótulo seção -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/name"
                    android:textColor="@color/journalMuted"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08" />

                <!-- Campo nome -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/InputOutlined"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:startIconDrawable="@drawable/ic_person_24"
                    app:startIconTint="@color/journalMuted">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editTextName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/name"
                        android:inputType="textPersonName"
                        android:textColor="@color/journalInk" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Botão salvar -->
                <Button
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:backgroundTint="@color/colorAccent"
                    android:onClick="saveProfile"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:text="@string/save_profile"
                    android:textColor="@color/white"
                    android:textSize="16sp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
