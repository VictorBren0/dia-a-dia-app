<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_auth_screen"
    android:fillViewport="true"
    tools:context=".activities.LoginActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingTop="72dp"
        android:paddingEnd="28dp"
        android:paddingBottom="48dp">

        <!-- Nome do app -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/app_name"
            android:textColor="@color/white"
            android:textSize="36sp"
            android:fontFamily="serif"
            android:textStyle="bold"
            android:letterSpacing="0.04" />

        <!-- Tagline -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/login_subtitle"
            android:textAlignment="center"
            android:textColor="@color/journalHighlight"
            android:textSize="14sp" />

        <!-- Card principal -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:background="@drawable/bg_surface_card"
            android:elevation="10dp"
            android:orientation="vertical"
            android:padding="28dp">

            <!-- Título do card -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/login_title"
                android:textColor="@color/journalInk"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/env_app_tagline"
                android:textColor="@color/journalMuted"
                android:textSize="13sp" />

            <!-- Fragment e-mail -->
            <androidx.fragment.app.FragmentContainerView
                android:id="@+id/fragmentEmail"
                android:name="dev.victorbreno.diaadia.fragments.EmailInputFragment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp" />

            <!-- Fragment senha -->
            <androidx.fragment.app.FragmentContainerView
                android:id="@+id/fragmentPassword"
                android:name="dev.victorbreno.diaadia.fragments.PasswordInputFragment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp" />

            <!-- Esqueci minha senha -->
            <TextView
                android:id="@+id/forgotPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="10dp"
                android:onClick="forgotPassword"
                android:text="@string/forgot_password"
                android:textColor="@color/colorPrimary"
                android:textSize="13sp" />

            <!-- Fragment botão entrar -->
            <androidx.fragment.app.FragmentContainerView
                android:id="@+id/fragmentButtonSignIn"
                android:name="dev.victorbreno.diaadia.fragments.ButtonFragment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp" />

            <Button
                android:id="@+id/buttonGoogleSignIn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/white"
                android:onClick="signInWithGoogle"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:text="@string/google_sign_in"
                android:textColor="@color/colorPrimary"
                android:textSize="16sp" />

            <!-- Divisor -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp"
                android:background="@color/journalDivider" />

            <!-- Link cadastro -->
            <TextView
                android:id="@+id/linkToRegister"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:onClick="goToRegisterPage"
                android:text="@string/create_account_link"
                android:textColor="@color/colorPrimary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>